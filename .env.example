# 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值
# 注意：.env 文件包含敏感信息，不要提交到版本控制系统

# ===========================================
# LLM API 配置
# ===========================================

# LLM API 密钥（示例：OpenAI API Key）
LLM_API_KEY=your_api_key_here

# LLM API 基础 URL（可选，用于自定义端点）
LLM_API_BASE_URL=https://api.openai.com/v1

# LLM 模型名称
LLM_MODEL_NAME=gpt-3.5-turbo

# LLM 请求超时时间（秒）
LLM_TIMEOUT=60

# ===========================================
# 数据源配置
# ===========================================

# 巨潮资讯网相关配置（如需要）
CNINFO_BASE_URL=https://www.cninfo.com.cn

# 数据下载间隔（秒，避免频繁请求）
DOWNLOAD_INTERVAL=2

# ===========================================
# 项目路径配置
# ===========================================

# 数据目录
DATA_DIR=data

# 输出目录
OUTPUT_DIR=outputs

# 日志级别
LOG_LEVEL=INFO

# ===========================================
# 其他配置
# ===========================================

# 是否启用详细日志
VERBOSE=false

# 最大并发数
MAX_WORKERS=4